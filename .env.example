# Optional: allow dashboard "Re-import static content" in production (default: disabled)
# ALLOW_DB_SEED=true

# Vercel (optional — see DEPLOYMENT.md for full steps)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/nebco
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# MongoDB connection string
# No auth (local dev):
#   mongodb://127.0.0.1:27017/nebco
# With auth (production VPS):
#   mongodb://nebco:YOUR_PASSWORD@127.0.0.1:27017/nebco?authSource=nebco
MONGODB_URI=mongodb://127.0.0.1:27017/nebco

# JWT secret for admin authentication (use: openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-secret-key

# Default admin credentials (used only during seed / reset-admin)
ADMIN_EMAIL=admin@nebco.com.np
ADMIN_PASSWORD=Admin@Nebco2024

# Public site URL — MUST match the exact URL you open in the browser (include port).
# Set BEFORE `npm run build`. Rebuild after changing.
#
# Local dev:        http://localhost:3000
# VPS (no domain):  http://YOUR_VPS_IP:3010   (use 3010 if 3000/3001 are taken)
# Domain + SSL:     https://nebco.com.np
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App listen port — must match the port in NEXT_PUBLIC_SITE_URL.
# Use 3010 on VPS when 3000 and 3001 are already in use.
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

# Email notifications for contact inquiries (optional — inquiries still save without these)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
NOTIFY_EMAIL=nebconepal@gmail.com

# Google Analytics Data API (optional — powers visitor stats in Admin → Analytics)
# Numeric GA4 property ID (also configurable in Admin → SEO). Env overrides DB.
# GA4_PROPERTY_ID=123456789
#
# Service account JSON (single line) or base64-encoded JSON from Google Cloud.
# Grant the service account "Viewer" on your GA4 property (Admin → Property access).
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Alternative: path to service account key file on the server
# GOOGLE_APPLICATION_CREDENTIALS=/var/www/nebco/ga4-service-account.json
