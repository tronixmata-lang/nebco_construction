# MongoDB connection string
# No auth (local dev):
#   mongodb://127.0.0.1:27017/nebco
# With auth (production VPS):
#   mongodb://nebco:YOUR_PASSWORD@127.0.0.1:27017/nebco?authSource=nebco
MONGODB_URI=mongodb://127.0.0.1:27017/nebco

# JWT secret for admin authentication (use: openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-secret-key

# Default admin credentials (used only during seed / reset-admin)
ADMIN_EMAIL=admin@nebco.com.np
ADMIN_PASSWORD=Admin@Nebco2024

# Public site URL — MUST match the exact URL you open in the browser (include port).
# Set BEFORE `npm run build`. Rebuild after changing.
#
# Local dev:        http://localhost:3000
# VPS (no domain):  http://YOUR_VPS_IP:3000   <-- use this for IP-only hosting
# Domain + SSL:     https://nebco.com.np
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App listen port — must match Nginx proxy_pass (deploy/nginx*.conf use 3000).
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

# Email notifications for contact inquiries (optional — inquiries still save without these)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
NOTIFY_EMAIL=nebconepal@gmail.com
