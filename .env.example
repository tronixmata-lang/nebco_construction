# MongoDB connection string (local VPS or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/nebco

# JWT secret for admin authentication (use: openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-secret-key

# Default admin credentials (used only during seed / reset-admin)
ADMIN_EMAIL=admin@nebco.com.np
ADMIN_PASSWORD=Admin@Nebco2024

# Public site URL — include port when not using standard 80/443
# Examples:
#   http://YOUR_VPS_IP:3000
#   http://nebco.com.np:3000
#   https://nebco.com.np          (only after SSL is working)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production server (optional — defaults shown)
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

# Email notifications for contact inquiries (optional — inquiries still save without these)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
NOTIFY_EMAIL=nebconepal@gmail.com
