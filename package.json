{
  "name": "nebco-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "dev:clean": "node -e \"const fs=require('fs'),p=require('path');try{fs.rmSync(p.join(process.cwd(),'.next'),{recursive:true,force:true})}catch{}\" && next dev --turbo",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "reset-admin": "tsx --env-file=.env.local scripts/reset-admin-password.ts",
    "start:prod": "NODE_ENV=production next start",
    "deploy": "bash scripts/deploy.sh",
    "setup:vps": "bash scripts/vps-setup.sh"
  },
  "dependencies": {
    "@serwist/next": "^9.5.11",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.20.0",
    "mongoose": "^9.7.0",
    "next": "15.3.9",
    "nodemailer": "^9.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "15.3.9",
    "serwist": "^9.5.11",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
